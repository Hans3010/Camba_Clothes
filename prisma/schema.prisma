// CambaClothes POS — Schema Prisma
// PostgreSQL · 13 tablas · Prisma 6

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Rol {
  ADMIN
  VENDEDOR
}

enum EstadoGeneral {
  ACTIVO
  INACTIVO
}

enum Temporada {
  PRIMAVERA
  VERANO
  OTONO
  INVIERNO
  TODO_EL_ANNO
}

enum EstadoSesion {
  ABIERTA
  CERRADA
}

enum EstadoVenta {
  COMPLETADA
  ANULADA
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  QR
}

// ─────────────────────────────────────────────
// TABLAS
// ─────────────────────────────────────────────

/// Tipos de usuario del sistema (ADMIN / VENDEDOR)
model tipoUsuario {
  id      Int       @id @default(autoincrement())
  rol     Rol       @unique
  Usuario Usuario[]
}

/// Usuarios del sistema con autenticación
model Usuario {
  id             Int         @id @default(autoincrement())
  idTipoUsuario  Int
  tipoUsuario    tipoUsuario @relation(fields: [idTipoUsuario], references: [id])
  usuario        String      @unique
  password       String
  estado         EstadoGeneral @default(ACTIVO)

  sesiones       sesionCaja[]
  ventas         Venta[]
  compras        Compra[]
  movimientos    movimientoInventario[]
}

/// Categorías de producto (Camisa, Pantalón, Vestido, etc.)
model categoriaProducto {
  id              Int       @id @default(autoincrement())
  nombreCategoria String
  descripcion     String?
  productos       Producto[]
}

/// Productos del catálogo con stock y margen de ganancia
model Producto {
  id                  Int               @id @default(autoincrement())
  idCategoriaProducto Int
  categoria           categoriaProducto @relation(fields: [idCategoriaProducto], references: [id])
  nombreProducto      String
  precioVenta         Decimal           @db.Decimal(10, 2)
  marca               String?
  talla               String
  color               String
  temporada           Temporada         @default(TODO_EL_ANNO)
  costo               Decimal           @db.Decimal(10, 2)
  /// Margen calculado: ((precioVenta - costo) / precioVenta) * 100
  margen              Decimal           @db.Decimal(5, 2)
  stock               Int               @default(0)
  stockMinimo         Int               @default(5)
  estado              EstadoGeneral     @default(ACTIVO)

  detallesVenta   detalleVenta[]
  detallesCompra  detalleCompra[]
  movimientos     movimientoInventario[]
}

/// Proveedores de mercadería
model Proveedor {
  id            Int       @id @default(autoincrement())
  nombreEmpresa String
  representante String?
  telefono      String
  correo        String?
  ubicacion     String?
  compras       Compra[]
}

/// Clientes de la boutique
model Cliente {
  id         Int     @id @default(autoincrement())
  nombre     String
  apPaterno  String
  apMaterno  String?
  telefono   String
  correo     String?
  ventas     Venta[]
}

/// Métodos de pago aceptados (Efectivo, Tarjeta, QR)
model tipoPago {
  id          Int        @id @default(autoincrement())
  tipoMetodo  MetodoPago @unique
  moneda      String     @default("BOB")
  ventas      Venta[]
}

/// Sesión de caja — debe estar abierta para registrar ventas
model sesionCaja {
  id           Int          @id @default(autoincrement())
  idUsuario    Int
  usuario      Usuario      @relation(fields: [idUsuario], references: [id])
  horaApertura DateTime     @default(now())
  horaCierre   DateTime?
  montoInicial Decimal      @db.Decimal(10, 2)
  montoFinal   Decimal?     @db.Decimal(10, 2)
  estado       EstadoSesion @default(ABIERTA)
  ventas       Venta[]
}

/// Venta registrada en el POS
model Venta {
  id              Int         @id @default(autoincrement())
  idCliente       Int
  cliente         Cliente     @relation(fields: [idCliente], references: [id])
  idUsuario       Int
  usuario         Usuario     @relation(fields: [idUsuario], references: [id])
  idSesionCaja    Int
  sesionCaja      sesionCaja  @relation(fields: [idSesionCaja], references: [id])
  idTipoPago      Int
  tipoPago        tipoPago    @relation(fields: [idTipoPago], references: [id])
  fecha           DateTime    @default(now())
  estado          EstadoVenta @default(COMPLETADA)
  subtotal        Decimal     @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  motivoAnulacion String?
  detalles        detalleVenta[]
}

/// Líneas de detalle de cada venta
model detalleVenta {
  id         Int     @id @default(autoincrement())
  idVenta    Int
  venta      Venta   @relation(fields: [idVenta], references: [id])
  idProducto Int
  producto   Producto @relation(fields: [idProducto], references: [id])
  cantidad   Int
  /// Precio unitario al momento de la venta (histórico)
  precio     Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)
}

/// Compra de mercadería a un proveedor
model Compra {
  id              Int        @id @default(autoincrement())
  idUsuario       Int
  usuario         Usuario    @relation(fields: [idUsuario], references: [id])
  idProveedor     Int
  proveedor       Proveedor  @relation(fields: [idProveedor], references: [id])
  fecha           DateTime   @default(now())
  numeroDocumento String?
  tipoDocumento   String?
  subtotal        Decimal    @db.Decimal(10, 2)
  descuento       Decimal    @db.Decimal(10, 2) @default(0)
  total           Decimal    @db.Decimal(10, 2)
  detalles        detalleCompra[]
}

/// Líneas de detalle de cada compra
model detalleCompra {
  id           Int      @id @default(autoincrement())
  idCompra     Int
  compra       Compra   @relation(fields: [idCompra], references: [id])
  idProducto   Int
  producto     Producto @relation(fields: [idProducto], references: [id])
  cantidad     Int
  precioCompra Decimal  @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(10, 2)
}

/// Log de auditoría de todos los movimientos de inventario
model movimientoInventario {
  id         Int            @id @default(autoincrement())
  idProducto Int
  producto   Producto       @relation(fields: [idProducto], references: [id])
  idUsuario  Int
  usuario    Usuario        @relation(fields: [idUsuario], references: [id])
  fecha      DateTime       @default(now())
  tipo       TipoMovimiento
  /// Positivo = entradas, negativo = salidas
  cantidad   Int
  descripcion String
}
